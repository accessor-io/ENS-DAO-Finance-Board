# ENS DAO Finance Schema Dashboard - Environment Configuration

# Etherscan API Configuration
# Get your API key from: https://etherscan.io/apis
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Dune Analytics API Configuration  
# Get your API key from: https://dune.com/docs/api/
VITE_DUNE_API_KEY=your_dune_api_key_here

# Optional: Custom API endpoints (defaults to official endpoints)
# VITE_ETHERSCAN_API_URL=https://api.etherscan.io/api
# VITE_DUNE_API_URL=https://api.dune.com/api/v1
# VITE_ENS_API_URL=https://api.ens.domains

# Optional: Cache configuration
# VITE_CACHE_DURATION=300000  # 5 minutes in milliseconds

# Optional: Auto-refresh interval
# VITE_AUTO_REFRESH_INTERVAL=300000  # 5 minutes in milliseconds 